# 數據庫配置
# 一般本機開發：picklevibes
# SaaS / PickCourt 開發（feature/picklecourt-platform）：picklevibes-saas-dev
MONGODB_URI=mongodb://localhost:27017/picklevibes-saas-dev

# JWT 密鑰
JWT_SECRET=your_jwt_secret_key_here

# Stripe 支付配置
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# 郵件配置
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Gmail SMTP 配置（用於歡迎郵件等功能）
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_digit_app_password
# EDM 批次：每封成功後間隔（毫秒），預設 300；SMTP 非中止錯誤後會指數 backoff
# EDM_SEND_GAP_MS=300

# SendGrid（若同時設定 API Key + EDM 範本 ID + FROM，則 EDM 改走 SendGrid Dynamic Template，其餘郵件仍可用上方 Gmail）
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_EDM_TEMPLATE_ID=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=newsletter@your-verified-domain.com
# SENDGRID_FROM_NAME=PickleVibes 匹克球場
# 未填主旨時寫入活動紀錄與傳給範本變數 subject 的預設字串
# SENDGRID_EDM_DEFAULT_SUBJECT=PickleVibes 消息
# SENDGRID_EDM_CHUNK=1000
# SENDGRID_EDM_BATCH_GAP_MS=200
# 同步 Marketing Contacts 時可選：SendGrid 列表 ID（逗號分隔）
# SENDGRID_MARKETING_LIST_IDS=

# 服務器配置
PORT=5000
NODE_ENV=development

# 前端URL（聯盟 deep link、郵件連結用）
CLIENT_URL=http://localhost:3000
# PickCourt 對外網址（testing / production 請改為 https://uat.pickcourt.hk）
PUBLIC_WEB_URL=http://localhost:3000

# 反向代理 hop 數（Nginx 前 1 層 = 1；Cloudflare + Nginx = 2）
TRUST_PROXY_HOPS=1

# 額外 CORS origins（逗號分隔，完全獨立域名時用）
# CORS_EXTRA_ORIGINS=https://lck.example.com,https://admin.lck.example.com

# 店鋪會員查詢豁免（曾預約限制不適用，可搜尋全部會員）— 預設荔枝角主店
# LEGACY_FULL_USER_LOOKUP_STORE_SLUGS=lai-chi-kok

# Twilio WhatsApp 配置
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Google Calendar 配置
GOOGLE_PROJECT_ID=your_google_project_id
GOOGLE_PRIVATE_KEY_ID=your_private_key_id
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=your_service_account_email@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=your_client_id

# 多環境 Google Calendar 配置
# 開發環境
GOOGLE_CALENDAR_DEVELOPMENT_ID=primary
GOOGLE_CALENDAR_DEVELOPMENT_PRIVATE_ID=

# UAT環境
GOOGLE_CALENDAR_UAT_ID=your_uat_calendar_id@group.calendar.google.com
GOOGLE_CALENDAR_UAT_PRIVATE_ID=

# 生產環境
GOOGLE_CALENDAR_PRODUCTION_ID=043b95582713f2c97975e59b6e56f1cf46f78c19bbaf6d9eb08b2292461ae903@group.calendar.google.com
GOOGLE_CALENDAR_PRODUCTION_PRIVATE_ID=


