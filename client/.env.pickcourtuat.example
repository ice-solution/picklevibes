# PickCourt UAT 前端 build 範例（複製為 .env.pickcourtuat）
# Cloudflare Flexible + Apache :80，對外仍為 https://uat.pickcourt.hk

REACT_APP_API_URL=https://uat.pickcourt.hk/api
REACT_APP_SERVER_URL=https://uat.pickcourt.hk
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
REACT_APP_NODE_ENV=uat
