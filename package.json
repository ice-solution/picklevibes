{
  "name": "picklevibes",
  "version": "1.0.0",
  "description": "Pickleball court booking and company website",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && PORT=3000 npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "start": "node server/index.js",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && PORT=3000 npm start",
    "heroku-postbuild": "cd client && npm install && npm run build",
    "seed": "node server/seed.js",
    "sync-calendar": "node server/scripts/syncGoogleCalendar.js",
    "smart-sync": "node server/scripts/smartSyncGoogleCalendar.js",
    "sync-today": "node server/scripts/smartSyncGoogleCalendar.js --today",
    "sync-month": "node server/scripts/smartSyncGoogleCalendar.js --month",
    "manage-sync": "node manage-sync.js",
    "export-users-sendgrid-csv": "node server/scripts/exportUsersCsvForSendgrid.js",
    "migrate-stores": "node server/scripts/migrateDefaultStore.js",
    "migrate-court-slugs": "node server/scripts/migrateCourtSlugs.js",
    "setup-isquare": "node server/scripts/setupIsquareStore.js",
    "batch-recharge": "node server/scripts/batchManualRecharge.js",
    "debug-finance": "node server/scripts/debugFinance.js",
    "verify-finance": "node server/scripts/verifyFinanceRevenue.js",
    "ensure-finance-indexes": "node server/scripts/ensureFinanceIndexes.js",
    "db-baseline-report": "node server/scripts/dbBaselineReport.js",
    "db-restore-saas-dev": "bash scripts/restore-saas-dev.sh",
    "migrate-store-tenant": "node server/scripts/migrateStoreTenantFields.js",
    "migrate-store-district": "node server/scripts/migrateStoreDistrict.js",
    "migrate-game-hall-store": "node server/scripts/migrateGameHallStore.js",
    "migrate-platform-membership": "node server/scripts/migratePlatformMembership.js",
    "verify-tenant-domains": "node server/scripts/verifyTenantDomains.js"
  },
  "keywords": [
    "pickleball",
    "booking",
    "sports",
    "website"
  ],
  "author": "Keith Leung",
  "license": "MIT",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@tuya/tuya-connector-nodejs": "^2.1.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "googleapis": "^128.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.4",
    "pug": "^3.0.3",
    "puppeteer": "^24.26.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.4",
    "socket.io": "^4.8.3",
    "stripe": "^13.5.0",
    "twilio": "^5.10.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  }
}
