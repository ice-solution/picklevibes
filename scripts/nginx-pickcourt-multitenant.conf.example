# PickCourt 多租戶自訂域名 — Nginx 範例（testing / production）
#
# 重點：
# 1. 所有店鋪域名 + 平台主域名都指向同一 SPA + API
# 2. 必須轉發 Host / X-Forwarded-* 供 tenant/resolve 解析
# 3. SPA 路由需 fallback 到 index.html
#
# 使用前：
#   - 替換 YOUR_TESTING_HOST、SSL 憑證路徑
#   - npm run build 後 static root 指向 client/build
#   - Node API 監聽 127.0.0.1:5001（或你的 PORT）

upstream pickcourt_api {
  server 127.0.0.1:5001;
  keepalive 32;
}

# HTTP → HTTPS（可選）
server {
  listen 80;
  server_name
    pickcourt.hk
    www.pickcourt.hk
    uat.pickcourt.hk
    lck.uat.pickcourt.hk
    admin.lck.uat.pickcourt.hk;
  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  server_name
    pickcourt.hk
    www.pickcourt.hk
    uat.pickcourt.hk
    lck.uat.pickcourt.hk
    admin.lck.uat.pickcourt.hk;

  # ssl_certificate     /etc/letsencrypt/live/uat.pickcourt.hk/fullchain.pem;
  # ssl_certificate_key /etc/letsencrypt/live/uat.pickcourt.hk/privkey.pem;

  root /var/www/pickcourt/client/build;
  index index.html;

  client_max_body_size 20m;

  # API → Node（保留 Host）
  location /api/ {
    proxy_pass http://pickcourt_api;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header Connection "";
  }

  # 上傳靜態（若 API 亦提供 /api/uploads）
  location /api/uploads/ {
    proxy_pass http://pickcourt_api;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Host $host;
  }

  # SPA — React Router（含 /store/...、/booking/...、/login）
  location / {
    try_files $uri $uri/ /index.html;
  }
}

# 通配子域名（新加盟店只需 DNS CNAME，不必改 Nginx）
# 需 DNS: *.uat.pickcourt.hk → 此伺服器 + 通配 SSL
#
# server {
#   listen 443 ssl http2;
#   server_name *.uat.pickcourt.hk;
#   ... 同上 location 區塊 ...
# }
