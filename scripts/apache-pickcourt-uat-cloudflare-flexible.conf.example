# PickCourt UAT — Apache2 + Cloudflare Flexible SSL
# 用戶 → Cloudflare：HTTPS；Cloudflare → 源站：HTTP :80
# 源站只需此 :80 VirtualHost（勿設 443 / SSLEngine / HTTP→HTTPS 301）
#
# 佔位符（由 setup-apache-pickcourt-uat.sh 取代）：
#   @APP_ROOT@   例：/var/www/html/pickcourt/client/build
#   @API_PORT@   例：5001
#
# Cloudflare：SSL/TLS → Flexible

<VirtualHost *:80>
    ServerName uat.pickcourt.hk
    ServerAlias lck.uat.pickcourt.hk admin.lck.uat.pickcourt.hk

    DocumentRoot @APP_ROOT@

    ErrorLog  ${APACHE_LOG_DIR}/pickcourt-uat-error.log
    CustomLog ${APACHE_LOG_DIR}/pickcourt-uat-access.log combined

    LimitRequestBody 20971520

    ProxyPreserveHost On
    ProxyTimeout 300
    Timeout 300

    # Socket.IO（Game client 等）
    ProxyPass /socket.io/ http://127.0.0.1:@API_PORT@/socket.io/
    ProxyPassReverse /socket.io/ http://127.0.0.1:@API_PORT@/socket.io/
    RewriteEngine On
    RewriteCond %{HTTP:Upgrade} =websocket [NC]
    RewriteRule ^/socket.io/(.*) ws://127.0.0.1:@API_PORT@/socket.io/$1 [P,L]
    RewriteCond %{HTTP:Upgrade} !=websocket [NC]
    RewriteRule ^/socket.io/(.*) http://127.0.0.1:@API_PORT@/socket.io/$1 [P,L]

    # API（必須保留 Host，供 tenant/resolve）
    ProxyPass /api http://127.0.0.1:@API_PORT@/api
    ProxyPassReverse /api http://127.0.0.1:@API_PORT@/api

    RequestHeader set X-Forwarded-Proto "https"
    RequestHeader set X-Forwarded-Host expr=%{HTTP_HOST}
    RequestHeader set X-Real-IP expr=%{REMOTE_ADDR}

    # ── React SPA：子路徑（/admin、/search、/login…）必須 fallback 到 index.html ──
    # 注意：只有 / 會自動讀 index.html；/admin/ 等若無此規則會 Apache 404
    RewriteCond %{REQUEST_URI} !^/api
    RewriteCond %{REQUEST_URI} !^/socket\.io
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} !-f
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} !-d
    RewriteRule ^ /index.html [L]

    <Directory @APP_ROOT@>
        Options -Indexes +FollowSymLinks
        AllowOverride None
        Require all granted
        # 雙保險（Apache 2.4+）
        FallbackResource /index.html
    </Directory>

    <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp)$">
        ExpiresActive On
        ExpiresDefault "access plus 1 year"
        Header set Cache-Control "public, immutable"
    </FilesMatch>

    <IfModule mod_deflate.c>
        AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
    </IfModule>

    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    <IfModule mod_remoteip.c>
        RemoteIPHeader CF-Connecting-IP
        RemoteIPTrustedProxy 173.245.48.0/20
        RemoteIPTrustedProxy 103.21.244.0/22
        RemoteIPTrustedProxy 103.22.200.0/22
        RemoteIPTrustedProxy 103.31.4.0/22
        RemoteIPTrustedProxy 141.101.64.0/18
        RemoteIPTrustedProxy 108.162.192.0/18
        RemoteIPTrustedProxy 190.93.240.0/20
        RemoteIPTrustedProxy 188.114.96.0/20
        RemoteIPTrustedProxy 197.234.240.0/22
        RemoteIPTrustedProxy 198.41.128.0/17
        RemoteIPTrustedProxy 162.158.0.0/15
        RemoteIPTrustedProxy 104.16.0.0/13
        RemoteIPTrustedProxy 104.24.0.0/14
        RemoteIPTrustedProxy 172.64.0.0/13
        RemoteIPTrustedProxy 131.0.72.0/22
    </IfModule>
</VirtualHost>
